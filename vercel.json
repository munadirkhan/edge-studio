{
  "rewrites": [
    {
      "source": "/video/:path*",
      "destination": "https://es-backend.fly.dev/video/:path*"
    },
    {
      "source": "/clips/:path*",
      "destination": "https://es-backend.fly.dev/clips/:path*"
    },
    {
      "source": "/health",
      "destination": "https://es-backend.fly.dev/health"
    },
    {
      "source": "/api/:path*",
      "destination": "https://es-backend.fly.dev/api/:path*"
    }
  ]
}

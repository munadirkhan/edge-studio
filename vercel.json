{
  "rewrites": [
    {
      "source": "/video/:path*",
      "destination": "https://edge-studio-production.up.railway.app/video/:path*",
      "methods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"]
    },
    {
      "source": "/clips/:path*",
      "destination": "https://edge-studio-production.up.railway.app/clips/:path*"
    },
    {
      "source": "/health",
      "destination": "https://edge-studio-production.up.railway.app/health"
    },
    {
      "source": "/api/:path*",
      "destination": "https://edge-studio-production.up.railway.app/api/:path*",
      "methods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"]
    }
  ]
}
